        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"model\": \"meta/llama-3.1-70b-instruct\", \"messages\": [{\"role\": \"system\", \"content\": \"You are a viral YouTube scriptwriter. Output ONLY valid JSON with keys: title (string, viral YouTube title using shock+specific+timeframe), script (string, 60-second script starting with Shock->Question->Promise hook, with curiosity loops, short sentences), thumbText (string, 3-word max high-shock thumbnail text), keyword (string, one short keyword describing the video topic like AI, jobs, money, future).\"}, {\"role\": \"user\", \"content\": \"Topic: {{$json.topic}}\"}], \"response_format\": {\"type\": \"json_object\"}}",
        "options": {}
